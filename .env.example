# Copy this file to .env or .env.local and replace <db_password>
MONGO_URI=mongodb+srv://brunooselladev_db_user:<db_password>@maps.0t4gzh0.mongodb.net/?retryWrites=true&w=majority&appName=Maps
MONGO_DB_NAME=rio-cuarto-grimoire
JWT_SECRET=replace_me_with_a_long_random_string
# Frontend: Google Maps / Places (POIModal, GooglePlacesInput)
VITE_API_GOOGLE=
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# --- IA del Mago / avatares (al menos una key; si no hay ninguna, el Mago usa respuestas de fallback) ---
# Gratis / barato (recomendado probar en este orden si no tenés créditos):
#   GEMINI_API_KEY   → https://aistudio.google.com/apikey (Google AI Studio, cuota gratuita)
#   GROQ_API_KEY     → https://console.groq.com/keys (tier gratuito con límites)
#   OPENROUTER_API_KEY → https://openrouter.ai/keys (modelos :free + router openrouter/free)

# Varias cuentas/keys: separá por coma (sin espacios alrededor o con trim). Orden = orden de fallback.
GROQ_API_KEY=
GROQ_MODEL=
GROQ_FAST_MODEL=

GEMINI_API_KEY=
GEMINI_MODEL=

# API oficial DeepSeek (key: https://platform.deepseek.com/api_keys). OpenAI-compatible.
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=

OPENROUTER_API_KEY=
OPENROUTER_MODEL=
OPENROUTER_ALT_MODEL=
OPENROUTER_QWEN_MODEL=
# Solo el ID del modelo en OpenRouter (ej. deepseek/deepseek-chat:free). NO es la API key de platform.deepseek.com
OPENROUTER_DEEPSEEK_MODEL=
OPENROUTER_SITE_URL=http://localhost:3001
OPENROUTER_SITE_NAME=Rio Cuarto Grimoire

OPENAI_API_KEY=
OPENAI_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=

CEREBRAS_API_KEY=
CEREBRAS_MODEL=

# Orden de fallback entre proveedores (nombres: groq, groq_fast, anthropic, openai, gemini, deepseek, openrouter, openrouter_alt, openrouter_qwen, openrouter_deepseek, cerebras)
# Ejemplo solo capas gratuitas típicas:
# LLM_PROVIDER_ORDER=gemini,groq,groq_fast,openrouter,openrouter_alt,openrouter_qwen,openrouter_deepseek

LLM_PROVIDER_ORDER=
LLM_TIMEOUT_MS=12000
LLM_RETRIES=1
LLM_DEBUG=false
